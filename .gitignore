# Environment — never commit real credentials
.env
.env.*
!.env.example

# Databases — local data, not for version control
*.db
*.sqlite
*.sqlite3

# ChromaDB persistent vector store — user data, large, not for version control
chroma_db/

# HuggingFace model cache (sentence-transformers downloads here)
.cache/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Test / scratch files
test_*.pdf
test_*.txt

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs
*.log
logs/
